# Quiver environment configuration
# Copy this file to .env and set values for your machine.
# .env is gitignored — never commit it.

# ──────────────────────────────────────────────
# WORDLISTS_PATH
# Path on your HOST machine to a wordlists directory.
# This gets bind-mounted into the container at /wordlists.
#
# If not set, Quiver uses ./data/wordlists/ (drop .txt files there).
#
# macOS — SecLists via Homebrew:
# WORDLISTS_PATH=/usr/share/seclists
#
# Linux — SecLists system install:
# WORDLISTS_PATH=/usr/share/seclists
#
# Linux — Kali default:
# WORDLISTS_PATH=/usr/share/wordlists
#
# Windows (WSL2) — SecLists cloned to home dir:
# WORDLISTS_PATH=/mnt/c/Users/yourname/SecLists
#
# Custom location (any OS):
# WORDLISTS_PATH=/path/to/your/wordlists
# ──────────────────────────────────────────────
